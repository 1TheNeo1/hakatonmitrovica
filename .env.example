# MitroStart Environment Variables

# Session secret — use any long random string
SESSION_SECRET=change-me-to-a-random-secret

# (Optional) Resend API key for sending OTP emails.
# If missing, OTPs are logged to the console instead.
RESEND_API_KEY=

# (Optional) Email to seed the admin user on first run.
ADMIN_EMAIL=admin@mitrostart.com

# Google Maps API key (existing)
GOOGLE_MAPS_API_KEY=

# OpenAI API key (existing)
OPENAI_API_KEY=
